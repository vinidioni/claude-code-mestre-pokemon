# Configuração do MCP Cooper
# Copie este arquivo para .env e preencha com seus valores

# Token de autenticação (obter no MCPHub)
# https://mcphub.intra.xiaojukeji.com/square
COOPER_TOKEN=SEU_TOKEN_AQUI

# URL da API (versão antiga - não requer LCA)
COOPER_API_URL=http://10.88.128.45/cooper_mcp/mcp

# Versão da API
COOPER_API_VERSION=legacy

# Timeout padrão (ms)
COOPER_TIMEOUT=30000
