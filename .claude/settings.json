{
  "statusLine": {
    "type": "command",
    "command": "echo \"[$(pwd | sed \"s|^$HOME|~\" | tail -c 30)] [$(git branch --show-current 2>/dev/null || echo 'none')] [claude]\""
  },
  "permissions": {
    "allow": [
      "Read(${workspaceFolder}/**)",
      "Read(${workspaceFolder}/.claude/**)",
      "Write(${workspaceFolder}/**)",
      "Edit(${workspaceFolder}/**)",
      "Bash(git *)",
      "Bash(node *)",
      "Bash(npm *)",
      "Bash(npx *)"
    ]
  }
}
