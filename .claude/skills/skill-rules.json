{
  "$schema": "./skill-rules-schema.json",
  "version": "1.0.0",
  "description": "Regras de ativação automática de skills baseadas em triggers e padrões de arquivo",
  "skills": [
    {
      "name": "conventionalCommits",
      "triggers": [
        "commit",
        "conventional commits",
        "mensagem de commit",
        "padrão de commit",
        "commit message"
      ],
      "filePatterns": [
        "**/.git/**",
        "**/CHANGELOG*",
        "**/.commitlintrc*"
      ],
      "description": "Padrão Conventional Commits para mensagens de commit estruturadas",
      "priority": "medium"
    },
    {
      "name": "reactPatterns",
      "triggers": [
        "react",
        "componente",
        "hook",
        "useState",
        "useEffect",
        "jsx",
        "tsx"
      ],
      "filePatterns": [
        "**/*.tsx",
        "**/*.jsx",
        "**/react/**"
      ],
      "description": "Padrões e boas práticas para desenvolvimento React",
      "priority": "medium"
    },
    {
      "name": "apiDesign",
      "triggers": [
        "api",
        "endpoint",
        "rest",
        "graphql",
        "rota",
        "controller"
