# DCC - Variáveis de Ambiente
#
# Copie este arquivo para .env e preencha com suas credenciais
# NUNCA commite o arquivo .env (já está no .gitignore)

# =============================================================================
# GITHUB (Obrigatório para MCP GitHub)
# =============================================================================
# Como obter: https://github.com/settings/tokens
# Scopes necessários: repo, read:user, read:org
GITHUB_TOKEN=ghp_seu_token_aqui

# =============================================================================
# GOOGLE WORKSPACE (Opcional - para Gmail, Calendar, Drive)
# =============================================================================
GOOGLE_CLIENT_SECRETS_PATH=/caminho/para/client_secret.json
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback

# =============================================================================
# D-CHAT / SMARTWORK (Opcional - apenas para funcionários DiDi/99)
# =============================================================================
# DWS_SCRIPT_PATH=/caminho/para/dws-windows.ps1

# =============================================================================
# CONFIGURAÇÕES OPCIONAIS
# =============================================================================
CLAUDE_DEFAULT_MODEL=sonnet
DEBUG=false
